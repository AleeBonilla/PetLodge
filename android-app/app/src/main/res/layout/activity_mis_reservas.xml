<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_color">

    <!-- Top Nav Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/white"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBackToMain"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            android:tint="@color/text_dark" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mis Reservas"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Reserva Activa: Max -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <!-- Left border indicator (Active = green) -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/success"
                    android:layout_marginEnd="12dp" />

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@color/bg_color"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_calendar"
                        android:tint="@color/success"
                        android:contentDescription="Reserva activa" />
                </FrameLayout>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reserva: Max"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activa"
                            android:textSize="12sp"
                            android:textColor="@color/success"
                            android:background="@color/bg_color"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15 Oct - 20 Oct"
                        android:textSize="13sp"
                        android:textColor="@color/text_light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Servicio: Alojamiento + Baño"
                        android:textSize="12sp"
                        android:textColor="@color/primary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Reserva Pendiente: Luna -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <!-- Left border indicator (Pending = warning) -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/warning"
                    android:layout_marginEnd="12dp" />

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@color/bg_color"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_clock"
                        android:tint="@color/warning"
                        android:contentDescription="Reserva pendiente" />
                </FrameLayout>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reserva: Luna"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendiente"
                            android:textSize="12sp"
                            android:textColor="@color/warning"
                            android:background="@color/bg_color"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25 Nov - 30 Nov"
                        android:textSize="13sp"
                        android:textColor="@color/text_light" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Servicio: Solo Alojamiento"
                            android:textSize="12sp"
                            android:textColor="@color/primary" />

                        <Button
                            android:id="@+id/btnCancelarReserva"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancelar"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/danger"
                            android:textSize="12sp"
                            android:minHeight="0dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Reserva Cancelada: Max -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:alpha="0.7"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <!-- Left border indicator (Cancelled = gray) -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/border_color"
                    android:layout_marginEnd="12dp" />

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@color/bg_color"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_cancel"
                        android:tint="@color/text_light"
                        android:contentDescription="Reserva cancelada" />
                </FrameLayout>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reserva: Max"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancelada"
                            android:textSize="12sp"
                            android:textColor="@color/text_light"
                            android:background="@color/bg_color"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01 Sep - 05 Sep"
                        android:textSize="13sp"
                        android:textColor="@color/text_light" />
                </LinearLayout>
            </LinearLayout>

            <!-- Create Reservation Button -->
            <Button
                android:id="@+id/btnCrearReserva"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="+ Crear Reserva"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
